# vim:set sw=4 ts=4 sts=4 et ft=fish fdm=marker fenc=utf-8:

command = /opt/homebrew/bin/fish -l

# theme = light: Violet Light,dark: Terafox
# theme = light:iTerm2 Solarized Light,dark:Solarized Dark Patched
# theme = light: Solarized Dark Patched,dark: Terafox
theme = Solarized Dark Patched

scrollback-limit = 10000

cursor-style               = block
cursor-style-blink         = true
shell-integration-features = no-title

macos-titlebar-style        = transparent
macos-non-native-fullscreen = false
macos-window-buttons        = visible

window-save-state        = never
window-width             = 109
window-height            = 30
window-position-x        = 340
window-position-y        = 90
window-inherit-font-size = false

quit-after-last-window-closed = true

# font-family  = "IosevkaTerm NFM Medium"
# font-family  = "IosevkaTerm NFM"
font-family  = "Iosevka Term SS08 Medium"
font-size    = 15
font-thicken = true

copy-on-select          = clipboard
mouse-hide-while-typing = true

desktop-notifications = false
bell-features = audio,title,attention

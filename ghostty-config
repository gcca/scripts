# vim:set sw=4 ts=4 sts=4 et ft=fish fdm=marker fenc=utf-8:

command = /opt/homebrew/bin/fish -l

theme = Terafox

scrollback-limit = 5000

cursor-style               = block
cursor-style-blink         = true
shell-integration-features = no-title

macos-titlebar-style        = hidden
macos-non-native-fullscreen = false
macos-window-buttons        = visible

window-save-state        = never
window-width             = 90
window-height            = 25
window-position-x        = 340
window-position-y        = 90
window-inherit-font-size = false

quit-after-last-window-closed = true

font-family  = "Iosevka NFM Light"
font-size    = 12
font-thicken = true

copy-on-select          = clipboard
mouse-hide-while-typing = true

desktop-notifications = false
bell-features = audio,title,attention

{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "mcp": {
    "xai-docs": {
      "enabled": false,
      "type": "remote",
      "url": "https://docs.x.ai/api/mcp"
    },
    "chrome-devtools": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--browserUrl=http://100.91.191.102:9222"
      ]
    }
  },
  "mode": {
    "build": {
      "description": "Grok 4.1 Fast Non-Reasoning",
      "model": "xai/grok-4-1-fast-non-reasoning",
      "temperature": 0.5,
      "options": {},
      "permission": {}
    },
    "plan": {
      "description": "Plan agent: Grok 4.3",
      "model": "xai/grok-4.3",
      "temperature": 0.2,
      "options": {},
      "permission": {}
    }
  },
  "model": "xai/grok-code-fast-1",
  "permission": {
    "*": "allow"
  }
}
